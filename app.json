{
  "expo": {
    "name": "Yaqin Market",
    "slug": "yaqin-market",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "yaqinmarket",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "uz.yaqin.market",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Yaqin do'konlarni topish uchun joylashuvingiz kerak",
        "NSLocationAlwaysUsageDescription": "Yetkazib berish jarayonida joylashuvingizni mijozga ko'rsatish uchun, hatto ilova fon rejimida bo'lganda ham",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Yetkazib berish jarayonida joylashuvingizni mijozga ko'rsatish uchun, hatto ilova fon rejimida bo'lganda ham",
        "NSCameraUsageDescription": "Shtrix-kod skanerlash va mahsulot rasmlari uchun kamera kerak",
        "UIBackgroundModes": ["location"]
      },
      "config": {
        "googleMapsApiKey": "AIzaSyDyBFO5ucrm_p0mXcur2254b_jG0LJ88Zg"
      }
    },
    "android": {
      "package": "uz.yaqin.market",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0046AD",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ],
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDyBFO5ucrm_p0mXcur2254b_jG0LJ88Zg"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Yaqin do'konlarni topish uchun joylashuvingiz kerak",
          "locationAlwaysAndWhenInUsePermission": "Yetkazib berish jarayonida joylashuvingizni mijozga ko'rsatish uchun, hatto ilova fon rejimida bo'lganda ham",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "isIosBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0046AD",
          "androidMode": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFFFFF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "Do'kon va mahsulot rasmlarini qo'shish uchun galereyaga ruxsat kerak"
        }
      ],
      "expo-document-picker",
      "expo-sharing"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "tilav",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e92114b3-1380-4773-9645-1cf427e58d54"
      }
    }
  }
}
