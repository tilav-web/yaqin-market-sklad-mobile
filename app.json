{
  "expo": {
    "name": "Yaqin Market",
    "slug": "yaqin-market",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "yaqinmarket",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon",
      "bundleIdentifier": "uz.yaqin.market",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Yaqin do'konlarni topish uchun joylashuvingiz kerak",
        "NSLocationAlwaysUsageDescription": "Yetkazib berish jarayonida joylashuvingizni kuzatish uchun",
        "NSCameraUsageDescription": "Shtrix-kod skanerlash va mahsulot rasmlari uchun kamera kerak"
      },
      "config": {
        "googleMapsApiKey": "AIzaSyDyBFO5ucrm_p0mXcur2254b_jG0LJ88Zg"
      }
    },
    "android": {
      "package": "uz.yaqin.market",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0046AD",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "FOREGROUND_SERVICE",
        "VIBRATE",
        "CAMERA"
      ],
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDyBFO5ucrm_p0mXcur2254b_jG0LJ88Zg"
        }
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Yaqin do'konlarni topish uchun joylashuvingiz kerak",
          "locationAlwaysAndWhenInUsePermission": "Yetkazib berish uchun joylashuv kerak"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0046AD",
          "androidMode": "default"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0046AD",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "tilav"
  }
}
